{
  "name": "9router",
  "version": "1.0.0",
  "description": "A lightweight, fast router for Node.js HTTP servers",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "build": "node scripts/build.js"
  },
  "keywords": [
    "router",
    "http",
    "nodejs",
    "middleware",
    "lightweight",
    "fast"
  ],
  "author": "decolua",
  "license": "MIT",
  "dependencies": {
    "path-to-regexp": "^6.2.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/decolua/9router.git"
  },
  "bugs": {
    "url": "https://github.com/decolua/9router/issues"
  },
  "homepage": "https://github.com/decolua/9router#readme",
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
